{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "InventoryFlowDatabase": "Server=localhost,1433;Database=InventoryFlow;TrustServerCertificate=True"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "InventoryFlow.Api"
    }
  }
}
